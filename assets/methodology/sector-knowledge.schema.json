{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Sector Knowledge",
  "type": "object",
  "required": ["sector_name", "sector_slug", "hydrated_at", "model", "sub_sectors"],
  "properties": {
    "sector_name": { "type": "string", "minLength": 1 },
    "sector_slug": { "type": "string", "minLength": 1 },
    "hydrated_at": { "type": "string", "minLength": 1 },
    "model": { "type": "string", "minLength": 1 },
    "sub_sectors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/sub_sector_knowledge" }
    }
  },
  "definitions": {
    "evidence_item": {
      "type": "object",
      "required": ["claim", "source_title", "source_url"],
      "properties": {
        "claim": { "type": "string", "minLength": 1 },
        "source_title": { "type": "string", "minLength": 1 },
        "source_url": { "type": "string", "minLength": 1 },
        "confidence_note": { "type": "string" }
      }
    },
    "sub_sector_knowledge": {
      "type": "object",
      "required": [
        "sub_sector_name",
        "sector_economics",
        "sector_lifecycle",
        "margin_dynamics",
        "capital_allocation",
        "peer_landscape",
        "valuation_baseline",
        "competitive_dynamics",
        "turnaround_playbook",
        "regulatory_landscape",
        "cagr_achievability",
        "kill_factors"
      ],
      "properties": {
        "sub_sector_name": { "type": "string", "minLength": 1 },
        "sector_economics": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "sector_lifecycle": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "margin_dynamics": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "capital_allocation": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "peer_landscape": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "valuation_baseline": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "competitive_dynamics": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "turnaround_playbook": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "regulatory_landscape": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "cagr_achievability": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        },
        "kill_factors": {
          "type": "array", "minItems": 1,
          "items": { "$ref": "#/definitions/evidence_item" }
        }
      }
    }
  }
}
