{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Structured Analysis Overlay",
  "type": "object",
  "required": [
    "title",
    "scan_date",
    "version",
    "scan_parameters",
    "methodology_notes",
    "structured_candidates"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "scan_date": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "scan_parameters": {
      "type": "object",
      "required": [
        "scan_mode",
        "focus",
        "api"
      ],
      "properties": {
        "scan_mode": {
          "type": "string",
          "minLength": 1
        },
        "focus": {
          "type": "string",
          "minLength": 1
        },
        "api": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "methodology_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "structured_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/structured_candidate"
      }
    }
  },
  "definitions": {
    "screening_check": {
      "type": "object",
      "required": [
        "verdict",
        "evidence"
      ],
      "properties": {
        "verdict": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pcs_check": {
      "type": "object",
      "required": [
        "answer",
        "justification",
        "evidence"
      ],
      "properties": {
        "answer": {
          "type": "string",
          "minLength": 1
        },
        "justification": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "structured_candidate": {
      "type": "object",
      "required": [
        "ticker",
        "screening_inputs"
      ],
      "properties": {
        "ticker": {
          "type": "string",
          "minLength": 1
        },
        "evidence_context": {
          "type": "object"
        },
        "screening_inputs": {
          "type": "object",
          "required": [
            "industry_understandable",
            "industry_in_secular_decline",
            "double_plus_potential",
            "solvency",
            "dilution",
            "revenue_growth",
            "roic",
            "valuation"
          ],
          "properties": {
            "industry_understandable": {
              "type": "boolean"
            },
            "industry_in_secular_decline": {
              "type": "boolean"
            },
            "double_plus_potential": {
              "type": "boolean"
            },
            "solvency": { "$ref": "#/definitions/screening_check" },
            "dilution": { "$ref": "#/definitions/screening_check" },
            "revenue_growth": { "$ref": "#/definitions/screening_check" },
            "roic": { "$ref": "#/definitions/screening_check" },
            "valuation": { "$ref": "#/definitions/screening_check" }
          }
        },
        "analysis_inputs": {
          "type": "object"
        },
        "epistemic_inputs": {
          "type": "object",
          "properties": {
            "q1_operational": { "$ref": "#/definitions/pcs_check" },
            "q2_regulatory": { "$ref": "#/definitions/pcs_check" },
            "q3_precedent": { "$ref": "#/definitions/pcs_check" },
            "q4_nonbinary": { "$ref": "#/definitions/pcs_check" },
            "q5_macro": { "$ref": "#/definitions/pcs_check" }
          }
        }
      }
    }
  }
}
