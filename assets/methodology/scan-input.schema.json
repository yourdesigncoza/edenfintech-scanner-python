{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EdenFinTech Scan Input",
  "$defs": {
    "screening_check": {
      "type": "object",
      "required": ["verdict", "note"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["PASS", "BORDERLINE_PASS", "FAIL"]
        },
        "note": {
          "type": "string"
        }
      }
    },
    "pcs_check": {
      "type": "object",
      "required": ["answer", "justification", "evidence"],
      "properties": {
        "answer": {
          "type": "string",
          "enum": ["STRONG", "MODERATE", "WEAK"]
        },
        "justification": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "thesis_invalidation_condition": {
      "type": "object",
      "required": ["category", "risk_description", "early_warning_metric", "evidence_status", "rationale"],
      "properties": {
        "category": {
          "type": "string",
          "enum": ["single_point_failure", "capital_structure", "regulatory", "tech_disruption", "market_structure"]
        },
        "risk_description": { "type": "string" },
        "early_warning_metric": { "type": "string" },
        "evidence_status": {
          "type": "string",
          "enum": ["no_current_evidence", "weak_evidence", "strong_evidence"]
        },
        "rationale": { "type": "string" }
      }
    },
    "thesis_invalidation": {
      "type": "object",
      "required": ["conditions", "imminent_break_flag"],
      "properties": {
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/thesis_invalidation_condition" }
        },
        "imminent_break_flag": { "type": "boolean" }
      }
    },
    "candidate": {
      "type": "object",
      "required": [
        "ticker",
        "cluster_name",
        "industry",
        "current_price",
        "screening"
      ],
      "properties": {
        "ticker": {
          "type": "string"
        },
        "cluster_name": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "current_price": {
          "type": "number",
          "minimum": 0
        },
        "screening": {
          "type": "object",
          "required": [
            "pct_off_ath",
            "industry_understandable",
            "industry_in_secular_decline",
            "double_plus_potential",
            "checks"
          ],
          "properties": {
            "pct_off_ath": {
              "type": "number"
            },
            "industry_understandable": {
              "type": "boolean"
            },
            "industry_in_secular_decline": {
              "type": "boolean"
            },
            "double_plus_potential": {
              "type": "boolean"
            },
            "checks": {
              "type": "object",
              "required": ["solvency", "dilution", "revenue_growth", "roic", "valuation"],
              "properties": {
                "solvency": { "$ref": "#/$defs/screening_check" },
                "dilution": { "$ref": "#/$defs/screening_check" },
                "revenue_growth": { "$ref": "#/$defs/screening_check" },
                "roic": { "$ref": "#/$defs/screening_check" },
                "valuation": { "$ref": "#/$defs/screening_check" }
              }
            }
          }
        },
        "analysis": {
          "type": "object",
          "required": [
            "margin_trend_gate",
            "final_cluster_status",
            "catalyst_classification",
            "dominant_risk_type",
            "base_case",
            "worst_case",
            "probability",
            "catalyst_stack",
            "invalidation_triggers",
            "decision_memo",
            "issues_and_fixes",
            "setup_pattern",
            "stretch_case"
          ],
          "properties": {
            "margin_trend_gate": {
              "type": "string",
              "enum": ["PASS", "PERMANENT_PASS"]
            },
            "final_cluster_status": {
              "type": "string",
              "enum": ["CLEAR_WINNER", "CONDITIONAL_WINNER", "LOWER_PRIORITY", "ELIMINATED"]
            },
            "catalyst_classification": {
              "type": "string",
              "enum": ["VALID_CATALYST", "SUPPORTING_TAILWIND", "WATCH_ONLY", "INVALID"]
            },
            "dominant_risk_type": {
              "type": "string",
              "enum": [
                "Operational/Financial",
                "Cyclical/Macro",
                "Regulatory/Political",
                "Legal/Investigation",
                "Structural fragility (SPOF)"
              ]
            },
            "base_case": {
              "type": "object",
              "required": ["revenue_b", "fcf_margin_pct", "multiple", "shares_m", "years"],
              "properties": {
                "revenue_b": { "type": "number" },
                "fcf_margin_pct": { "type": "number" },
                "multiple": { "type": "number" },
                "shares_m": { "type": "number", "minimum": 0 },
                "years": { "type": "number", "minimum": 0 },
                "discount_path": { "type": "string" }
              }
            },
            "worst_case": {
              "type": "object",
              "required": ["revenue_b", "fcf_margin_pct", "multiple", "shares_m"],
              "properties": {
                "revenue_b": { "type": "number" },
                "fcf_margin_pct": { "type": "number" },
                "multiple": { "type": "number" },
                "shares_m": { "type": "number", "minimum": 0 },
                "trough_path": {
                  "type": ["string", "object"]
                },
                "tbv_crosscheck": {
                  "type": ["string", "object"]
                }
              }
            },
            "probability": {
              "type": "object",
              "required": ["base_probability_pct"],
              "properties": {
                "base_probability_pct": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "base_rate": { "type": "string" },
                "likert_adjustments": { "type": "string" },
                "ceilings_applied": { "type": "string" },
                "threshold_proximity_warning": { "type": "string" }
              }
            },
            "catalyst_stack": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["type", "description", "timeline"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["HARD", "MEDIUM", "SOFT"]
                  },
                  "description": { "type": "string" },
                  "timeline": { "type": "string" }
                }
              }
            },
            "invalidation_triggers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["trigger", "evidence"],
                "properties": {
                  "trigger": { "type": "string" },
                  "evidence": { "type": "string" }
                }
              }
            },
            "decision_memo": {
              "type": "object",
              "required": ["better_than_peer", "safer_than_peer", "what_makes_wrong"],
              "properties": {
                "better_than_peer": { "type": "string" },
                "safer_than_peer": { "type": "string" },
                "what_makes_wrong": { "type": "string" }
              }
            },
            "issues_and_fixes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["issue", "fix", "evidence_status"],
                "properties": {
                  "issue": { "type": "string" },
                  "fix": { "type": "string" },
                  "evidence_status": {
                    "type": "string",
                    "enum": ["ANNOUNCED_ONLY", "ACTION_UNDERWAY", "EARLY_RESULTS_VISIBLE", "PROVEN"]
                  }
                }
              }
            },
            "setup_pattern": {
              "type": "string",
              "enum": ["SOLVENCY_SCARE", "QUALITY_FRANCHISE", "NARRATIVE_DISCOUNT", "NEW_OPERATOR", "OTHER"]
            },
            "stretch_case": {
              "type": "object",
              "required": ["revenue_b", "fcf_margin_pct", "multiple", "shares_m", "years"],
              "properties": {
                "revenue_b": { "type": "number" },
                "fcf_margin_pct": { "type": "number" },
                "multiple": { "type": "number" },
                "shares_m": { "type": "number", "minimum": 0 },
                "years": { "type": "number", "minimum": 0 },
                "discount_path": { "type": "string" }
              }
            },
            "moat_assessment": { "type": "string" },
            "thesis_summary": { "type": "string" },
            "catalysts": {
              "type": "array",
              "items": { "type": "string" }
            },
            "key_risks": {
              "type": "array",
              "items": { "type": "string" }
            },
            "key_financials": {
              "type": ["string", "object"]
            },
            "structural_diagnosis": {
              "type": ["string", "object"]
            },
            "human_judgment_flags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "source_research": {
              "type": "object",
              "properties": {
                "prompt_context": {
                  "type": "object",
                  "properties": {
                    "model": { "type": "string" },
                    "research_question": { "type": "string" },
                    "search_scope": { "type": "string" }
                  }
                },
                "research_notes": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "catalyst_evidence": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "risk_evidence": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "management_observations": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "moat_observations": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "precedent_observations": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "epistemic_anchors": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              }
            },
            "thesis_invalidation": { "$ref": "#/$defs/thesis_invalidation" },
            "exception_20_pct_gate": {
              "type": "object",
              "properties": {
                "eligible": {
                  "type": "boolean"
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          }
        },
        "epistemic_review": {
          "type": "object",
          "required": [
            "q1_operational_feasibility",
            "q2_risk_bounded",
            "q3_precedent_grounded",
            "q4_downside_steelmanned",
            "q5_catalyst_concrete"
          ],
          "properties": {
            "q1_operational_feasibility": { "$ref": "#/$defs/pcs_check" },
            "q2_risk_bounded": { "$ref": "#/$defs/pcs_check" },
            "q3_precedent_grounded": { "$ref": "#/$defs/pcs_check" },
            "q4_downside_steelmanned": { "$ref": "#/$defs/pcs_check" },
            "q5_catalyst_concrete": { "$ref": "#/$defs/pcs_check" }
          }
        }
      }
    }
  },
  "type": "object",
  "required": ["scan_parameters", "candidates"],
  "properties": {
    "title": {
      "type": "string"
    },
    "scan_date": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "scan_parameters": {
      "type": "object",
      "required": ["scan_mode", "focus"],
      "properties": {
        "scan_mode": {
          "type": "string",
          "enum": ["full_nyse", "sector", "specific_tickers"]
        },
        "focus": {
          "type": "string"
        },
        "api": {
          "type": "string"
        }
      }
    },
    "portfolio_context": {
      "type": "object",
      "properties": {
        "current_positions": {
          "type": "integer",
          "minimum": 0
        },
        "max_positions": {
          "type": "integer",
          "minimum": 1
        },
        "current_holdings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ticker"],
            "properties": {
              "ticker": {
                "type": "string"
              },
              "current_weight_pct": {
                "type": "number",
                "minimum": 0
              },
              "existing_position_action": {
                "type": "string",
                "enum": ["HOLD", "HOLD_AND_MONITOR", "TRIM", "REDUCE", "EXIT"]
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "methodology_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  }
}
