{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EdenFinTech Scan Input",
  "$defs": {
    "screening_check": {
      "type": "object",
      "required": ["verdict", "note"],
      "properties": {
        "verdict": {
          "type": "string",
          "enum": ["PASS", "BORDERLINE_PASS", "FAIL"]
        },
        "note": {
          "type": "string"
        }
      }
    },
    "pcs_check": {
      "type": "object",
      "required": ["answer", "justification", "evidence"],
      "properties": {
        "answer": {
          "type": "string",
          "enum": ["Yes", "No"]
        },
        "justification": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        }
      }
    },
    "candidate": {
      "type": "object",
      "required": [
        "ticker",
        "cluster_name",
        "industry",
        "current_price",
        "screening"
      ],
      "properties": {
        "ticker": {
          "type": "string"
        },
        "cluster_name": {
          "type": "string"
        },
        "industry": {
          "type": "string"
        },
        "current_price": {
          "type": "number",
          "minimum": 0
        },
        "screening": {
          "type": "object",
          "required": [
            "pct_off_ath",
            "industry_understandable",
            "industry_in_secular_decline",
            "double_plus_potential",
            "checks"
          ],
          "properties": {
            "pct_off_ath": {
              "type": "number"
            },
            "industry_understandable": {
              "type": "boolean"
            },
            "industry_in_secular_decline": {
              "type": "boolean"
            },
            "double_plus_potential": {
              "type": "boolean"
            },
            "checks": {
              "type": "object",
              "required": ["solvency", "dilution", "revenue_growth", "roic", "valuation"],
              "properties": {
                "solvency": { "$ref": "#/$defs/screening_check" },
                "dilution": { "$ref": "#/$defs/screening_check" },
                "revenue_growth": { "$ref": "#/$defs/screening_check" },
                "roic": { "$ref": "#/$defs/screening_check" },
                "valuation": { "$ref": "#/$defs/screening_check" }
              }
            }
          }
        },
        "analysis": {
          "type": "object",
          "required": [
            "margin_trend_gate",
            "final_cluster_status",
            "catalyst_classification",
            "dominant_risk_type",
            "base_case",
            "worst_case",
            "probability"
          ],
          "properties": {
            "margin_trend_gate": {
              "type": "string",
              "enum": ["PASS", "PERMANENT_PASS"]
            },
            "final_cluster_status": {
              "type": "string",
              "enum": ["CLEAR_WINNER", "CONDITIONAL_WINNER", "LOWER_PRIORITY", "ELIMINATED"]
            },
            "catalyst_classification": {
              "type": "string",
              "enum": ["VALID_CATALYST", "SUPPORTING_TAILWIND", "WATCH_ONLY", "INVALID"]
            },
            "dominant_risk_type": {
              "type": "string",
              "enum": [
                "Operational/Financial",
                "Cyclical/Macro",
                "Regulatory/Political",
                "Legal/Investigation",
                "Structural fragility (SPOF)"
              ]
            },
            "base_case": {
              "type": "object",
              "required": ["revenue_b", "fcf_margin_pct", "multiple", "shares_m", "years"],
              "properties": {
                "revenue_b": { "type": "number" },
                "fcf_margin_pct": { "type": "number" },
                "multiple": { "type": "number" },
                "shares_m": { "type": "number", "minimum": 0 },
                "years": { "type": "number", "minimum": 0 },
                "discount_path": { "type": "string" }
              }
            },
            "worst_case": {
              "type": "object",
              "required": ["revenue_b", "fcf_margin_pct", "multiple", "shares_m"],
              "properties": {
                "revenue_b": { "type": "number" },
                "fcf_margin_pct": { "type": "number" },
                "multiple": { "type": "number" },
                "shares_m": { "type": "number", "minimum": 0 },
                "trough_path": {
                  "type": "object"
                },
                "tbv_crosscheck": {
                  "type": "object"
                }
              }
            },
            "probability": {
              "type": "object",
              "required": ["base_probability_pct"],
              "properties": {
                "base_probability_pct": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 100
                },
                "base_rate": { "type": "string" },
                "likert_adjustments": { "type": "string" },
                "ceilings_applied": { "type": "string" },
                "threshold_proximity_warning": { "type": "string" }
              }
            },
            "issues_and_fixes": { "type": "string" },
            "moat_assessment": { "type": "string" },
            "thesis_summary": { "type": "string" },
            "catalysts": {
              "type": "array",
              "items": {}
            },
            "key_risks": {
              "type": "array",
              "items": {}
            },
            "key_financials": {
              "type": "object"
            },
            "structural_diagnosis": {
              "type": "object"
            },
            "human_judgment_flags": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "source_research": {
              "type": "object",
              "properties": {
                "prompt_context": {
                  "type": "object",
                  "properties": {
                    "model": { "type": "string" },
                    "research_question": { "type": "string" },
                    "search_scope": { "type": "string" }
                  }
                },
                "research_notes": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "catalyst_evidence": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "risk_evidence": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "management_observations": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "moat_observations": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "precedent_observations": {
                  "type": "array",
                  "items": { "type": "object" }
                },
                "epistemic_anchors": {
                  "type": "array",
                  "items": { "type": "object" }
                }
              }
            },
            "exception_20_pct_gate": {
              "type": "object",
              "properties": {
                "eligible": {
                  "type": "boolean"
                },
                "reason": {
                  "type": "string"
                }
              }
            }
          }
        },
        "epistemic_review": {
          "type": "object",
          "required": [
            "q1_operational",
            "q2_regulatory",
            "q3_precedent",
            "q4_nonbinary",
            "q5_macro"
          ],
          "properties": {
            "q1_operational": { "$ref": "#/$defs/pcs_check" },
            "q2_regulatory": { "$ref": "#/$defs/pcs_check" },
            "q3_precedent": { "$ref": "#/$defs/pcs_check" },
            "q4_nonbinary": { "$ref": "#/$defs/pcs_check" },
            "q5_macro": { "$ref": "#/$defs/pcs_check" }
          }
        }
      }
    }
  },
  "type": "object",
  "required": ["scan_parameters", "candidates"],
  "properties": {
    "title": {
      "type": "string"
    },
    "scan_date": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "scan_parameters": {
      "type": "object",
      "required": ["scan_mode", "focus"],
      "properties": {
        "scan_mode": {
          "type": "string",
          "enum": ["full_nyse", "sector", "specific_tickers"]
        },
        "focus": {
          "type": "string"
        },
        "api": {
          "type": "string"
        }
      }
    },
    "portfolio_context": {
      "type": "object",
      "properties": {
        "current_positions": {
          "type": "integer",
          "minimum": 0
        },
        "max_positions": {
          "type": "integer",
          "minimum": 1
        },
        "current_holdings": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ticker"],
            "properties": {
              "ticker": {
                "type": "string"
              },
              "current_weight_pct": {
                "type": "number",
                "minimum": 0
              },
              "existing_position_action": {
                "type": "string",
                "enum": ["HOLD", "HOLD_AND_MONITOR", "TRIM", "REDUCE", "EXIT"]
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "methodology_notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  }
}
